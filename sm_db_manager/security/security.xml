<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="module_category_db_manager" model="ir.module.category">
        <field name="name">Database Manager</field>
        <field name="sequence">210</field>
    </record>

    <record id="group_db_manager_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="module_category_db_manager"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_db_manager_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="module_category_db_manager"/>
        <field name="implied_ids" eval="[(4, ref('group_db_manager_user'))]"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

</odoo>
